generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  favorites Favorite[]
  createdAt DateTime   @default(now())
}

model Favorite {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  githubRepoId    Int
  name            String
  description     String?
  stargazersCount Int
  htmlUrl         String
  language        String?
  fullName        String
  createdAt       DateTime @default(now())

  // Prevents a user from saving the same GitHub repo twice
  @@unique([userId, githubRepoId])
}
